# Frontend config for calling your deployed contracts
#
# Copy to `.env` and fill in values for your target network.

# Network
VITE_CHAIN_ID=11155111

# Your reToken hook deployed address (must be the mined hook address with BEFORE_SWAP|AFTER_SWAP flags)
VITE_HOOK_ADDRESS=0x0000000000000000000000000000000000000000

# Uniswap v4 SwapRouter address for your chain (the contract your UI calls to execute swaps)
VITE_SWAP_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# Pool tokens (IMPORTANT: TOKEN0_ADDRESS must be numerically smaller than TOKEN1_ADDRESS)
VITE_TOKEN0_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TOKEN1_ADDRESS=0x0000000000000000000000000000000000000000

# Uniswap v4 pool params
VITE_POOL_FEE=3000
VITE_TICK_SPACING=60

# Hook data passed to the router (your hook ignores it, so usually `0x`)
VITE_HOOK_DATA=0x

